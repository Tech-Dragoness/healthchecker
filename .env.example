# HealthChecker/.env.example
# Copy this file to "HealthChecker/.env" and fill in real values.
# This is the SINGLE place connection/secret info lives — every backend
# module reads from this file only (see app/db/connection.py and
# app/services/ai_service.py).

# ── Gemini API keys (up to 5, rotated automatically on rate limits) ──
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

# ── PostgreSQL connection ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=healthchecker
DB_USER=healthchecker_user
DB_PASSWORD=healthchecker_pass

# ── CORS / frontend origin ──
FRONTEND_URL=http://localhost:5173
